---
import Layout from "@/layouts/Layout.astro";
import { roadmaps } from "@/lib/roadmaps";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<Layout title="Roadmaps · The Madinah Way" description="Visual learning paths.">
  <section class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Roadmaps</h1>
    <p class="mt-2 text-slate-600">Visual learning paths. Click any step to read more and mark your progress.</p>
  </section>

  {roadmaps.length === 0 ? (
    <div class="rounded-xl border border-dashed border-slate-300 p-8 text-center text-sm text-slate-600">
      No roadmaps yet. Drop a JSON file in <code class="text-slate-700">src/data/roadmaps/</code>.
    </div>
  ) : (
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {roadmaps.map((r) => (
        <li
          class="roadmap-card rounded-xl border border-slate-200 bg-white p-5 transition hover:border-emerald-400"
          data-roadmap-id={r.id}
          data-node-ids={JSON.stringify(r.nodes.map((n) => n.id))}
        >
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-bold leading-tight">{r.title}</h2>
              <p class="mt-1 text-sm text-slate-600">{r.description}</p>
            </div>
            <span class="shrink-0 rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wider text-emerald-700">
              {r.nodes.length} steps
            </span>
          </div>
          <div class="mt-4">
            <div class="flex items-center justify-between text-xs text-slate-600">
              <span><span data-pct>0</span>% done</span>
              <span data-frac>0 / {r.nodes.length}</span>
            </div>
            <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-slate-100">
              <div class="h-full bg-emerald-400 transition-all duration-500" style="width: 0%" data-bar></div>
            </div>
          </div>
          <div class="mt-5 flex items-center justify-between">
            <a
              href={`${base}/roadmaps/${r.id}/`}
              class="rounded-lg bg-emerald-500 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-400"
            >Open</a>
            <span class="text-xs text-slate-500">{r.tags?.join(" · ")}</span>
          </div>
        </li>
      ))}
    </ul>
  )}

  <script is:inline>
    (function () {
      const VALID = new Set(["todo", "in-progress", "done"]);
      document.querySelectorAll(".roadmap-card").forEach((card) => {
        const id = card.dataset.roadmapId;
        let ids;
        try { ids = JSON.parse(card.dataset.nodeIds || "[]"); } catch { ids = []; }
        let statuses = {};
        try {
          const raw = localStorage.getItem(`a3:roadmap.${id}.status`);
          statuses = raw ? JSON.parse(raw) : {};
        } catch { /* noop */ }
        const total = ids.length;
        const done = ids.filter((nid) => statuses[nid] === "done" && VALID.has(statuses[nid])).length;
        const pct = total ? Math.round((done / total) * 100) : 0;
        card.querySelector("[data-pct]").textContent = String(pct);
        card.querySelector("[data-frac]").textContent = `${done} / ${total}`;
        card.querySelector("[data-bar]").style.width = `${pct}%`;
      });
    })();
  </script>
</Layout>
