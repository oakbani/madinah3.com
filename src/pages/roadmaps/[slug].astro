---
import Layout from "@/layouts/Layout.astro";
import Roadmap from "@/components/Roadmap.astro";
import { roadmaps, type Roadmap as RoadmapT } from "@/lib/roadmaps";

export function getStaticPaths() {
  return roadmaps.map((r) => ({
    params: { slug: r.id },
    props: { roadmap: r },
  }));
}

interface Props {
  roadmap: RoadmapT;
}
const { roadmap } = Astro.props as Props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const title = `${roadmap.title} — Roadmap · The Madinah Way`;
---
<Layout title={title} description={roadmap.description} ogType="article">
  <nav class="mb-4 text-sm text-slate-600">
    <a href={`${base}/`} class="hover:text-slate-800">Home</a>
    <span class="mx-2 text-slate-600">/</span>
    <a href={`${base}/roadmaps/`} class="hover:text-slate-800">Roadmaps</a>
    <span class="mx-2 text-slate-600">/</span>
    <span class="text-slate-700">{roadmap.title}</span>
  </nav>

  <header class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight">{roadmap.title}</h1>
    {roadmap.description && (
      <p class="mt-1 text-sm text-slate-600">{roadmap.description}</p>
    )}
  </header>

  <Roadmap roadmap={roadmap} />
</Layout>
