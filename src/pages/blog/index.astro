---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const LANG_LABEL: Record<string, string> = { en: "EN", ur: "اردو", ar: "العربية" };
---
<Layout title="Blog · madinah3">
  <header class="mb-8">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Blog<span class="text-emerald-400">.</span></h1>
    <p class="mt-2 text-slate-600">Short notes — in English, Urdu, and Arabic.</p>
  </header>

  {posts.length === 0 ? (
    <div class="rounded-xl border border-dashed border-slate-300 p-8 text-center text-sm text-slate-600">
      No posts yet. Add one under <code class="text-slate-700">src/content/blog/</code>.
    </div>
  ) : (
    <ul class="space-y-3">
      {posts.map((p) => {
        const rtl = p.data.lang === "ur" || p.data.lang === "ar";
        const fontClass =
          p.data.lang === "ur" ? "font-urdu" :
          p.data.lang === "ar" ? "font-arabic" : "";
        return (
          <li class="rounded-xl border border-slate-200 bg-white p-5 hover:border-slate-300">
            <a
              href={`${base}/blog/${p.slug}/`}
              class="flex items-start justify-between gap-4"
            >
              <div lang={p.data.lang} dir={rtl ? "rtl" : "ltr"} class:list={[fontClass, "min-w-0"]}>
                <h2 class="text-lg font-bold truncate">{p.data.title}</h2>
                {p.data.description && (
                  <p class="mt-1 text-sm text-slate-600 line-clamp-2">{p.data.description}</p>
                )}
              </div>
              <div class="shrink-0 text-right text-xs text-slate-500">
                <div>{p.data.date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" })}</div>
                <div class="mt-1 inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[10px] tracking-wide">
                  {LANG_LABEL[p.data.lang] ?? p.data.lang}
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  )}
</Layout>

<style is:global>
  .font-arabic { font-family: "Noto Naskh Arabic", serif; }
</style>
