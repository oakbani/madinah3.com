---
import Layout from "@/layouts/Layout.astro";
import { decks, type Deck } from "@/lib/decks";

export function getStaticPaths() {
  return decks.map((d) => ({
    params: { deck: d.id },
    props: { deck: d },
  }));
}

interface Props {
  deck: Deck;
}

const { deck } = Astro.props as Props;
const title = `${deck.title} — Flashcards · The Madinah Way`;
const description = deck.description;
---
<Layout title={title} description={description} ogType="article">
  <nav class="mb-4 text-sm text-slate-600">
    <a href="/" class="hover:text-slate-800">Home</a>
    <span class="mx-2 text-slate-600">/</span>
    <a href="/#flashcards" class="hover:text-slate-800">Flashcards</a>
    <span class="mx-2 text-slate-600">/</span>
    <span class="text-slate-700">{deck.title}</span>
  </nav>

  <header class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight">
      {deck.title}<span class="text-emerald-400">.</span>
    </h1>
    <p class="text-sm text-slate-600 mt-1">{deck.description}</p>
    <p class="text-xs text-slate-500 mt-2">
      Tap or press <kbd class="px-1.5 py-0.5 bg-slate-100 rounded text-[10px]">Space</kbd> to flip. Then say if you knew it.
    </p>
  </header>

  <!-- Toolbar -->
  <div class="mb-4 flex items-center gap-2">
    <select id="lang" class="bg-slate-100 border border-slate-300 rounded-lg text-sm px-3 py-2">
      <option value="en">English</option>
      <option value="ur">اردو</option>
    </select>
    <span class="ml-auto text-xs text-slate-600">
      <span id="learned-count">0</span> learned · <span id="remaining-count">{deck.cards.length}</span> remaining
    </span>
  </div>

  <div class="mb-4 h-1.5 bg-slate-100 rounded-full overflow-hidden">
    <div id="progress-bar" class="h-full bg-emerald-400 transition-all duration-500" style="width: 0%"></div>
  </div>

  <!-- Card stage -->
  <div class="scene relative mx-auto max-w-xl w-full">
    <div class="stack-card bg-slate-100 border border-slate-300 -z-20" style="transform: translateY(18px) scale(.94);"></div>
    <div class="stack-card bg-slate-100 border border-slate-300 -z-10" style="transform: translateY(9px) scale(.97);"></div>

    <div id="card" class="card-3d cursor-pointer select-none" role="button" aria-label="Flashcard. Tap to flip.">
      <div class="card-face card-front bg-gradient-to-br from-emerald-700 via-emerald-600 to-teal-600 shadow-2xl">
        <div class="w-full min-w-0">
          <div class="text-[11px] uppercase tracking-[0.25em] text-white/70 mb-3">Question</div>
          <div id="front-content" class="text-xl sm:text-3xl font-semibold leading-snug break-words"></div>
          <div class="mt-6 text-xs text-white/60 tap-hint">Tap to reveal</div>
        </div>
      </div>
      <div class="card-face card-back bg-gradient-to-br from-emerald-500 via-teal-500 to-cyan-600 shadow-2xl">
        <div class="w-full min-w-0">
          <div class="text-[11px] uppercase tracking-[0.25em] text-white/80 mb-3">Answer</div>
          <div id="back-content" class="text-2xl sm:text-4xl font-bold leading-snug break-words"></div>
        </div>
      </div>
    </div>

    <div id="empty" class="hidden absolute inset-0 rounded-2xl bg-white/95 border border-slate-300 flex flex-col items-center justify-center text-center p-6">
      <div class="text-3xl">🎉</div>
      <div class="mt-2 text-xl font-bold">All cards learned!</div>
      <div class="text-sm text-slate-600 mt-1">Reset progress or pick another deck.</div>
    </div>
  </div>

  <!-- Action buttons -->
  <div class="mt-6 grid grid-cols-2 gap-2 sm:gap-3 mx-auto max-w-xl">
    <button id="btn-didnt" class="rounded-xl bg-rose-600 hover:bg-rose-700 text-white border border-rose-700 px-3 sm:px-4 py-3 sm:py-4 font-semibold shadow-sm transition disabled:opacity-40 disabled:cursor-not-allowed">
      <div class="text-sm sm:text-base">Didn't know</div>
      <div class="hidden sm:block text-[11px] text-white/80 mt-0.5">Press <kbd class="px-1 py-0.5 bg-white/20 rounded">←</kbd> — repeats later</div>
    </button>
    <button id="btn-knew" class="rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white border border-emerald-700 px-3 sm:px-4 py-3 sm:py-4 font-semibold shadow-sm transition disabled:opacity-40 disabled:cursor-not-allowed">
      <div class="text-sm sm:text-base">I knew it</div>
      <div class="hidden sm:block text-[11px] text-white/80 mt-0.5">Press <kbd class="px-1 py-0.5 bg-white/20 rounded">→</kbd> — marks learned</div>
    </button>
  </div>

  <div class="mt-4 grid grid-cols-3 gap-2 sm:flex sm:flex-wrap sm:justify-center mx-auto max-w-xl">
    <button id="btn-flip" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2 sm:px-3 py-2 text-xs sm:text-sm font-semibold text-slate-700 shadow-sm hover:border-emerald-500 hover:text-emerald-700">
      <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h13a4 4 0 0 1 4 4v0"/><path d="M6 4 3 7l3 3"/><path d="M21 17H8a4 4 0 0 1-4-4v0"/><path d="m18 20 3-3-3-3"/></svg>
      <span>Flip<span class="hidden sm:inline">&nbsp;(Space)</span></span>
    </button>
    <button id="btn-shuffle" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2 sm:px-3 py-2 text-xs sm:text-sm font-semibold text-slate-700 shadow-sm hover:border-emerald-500 hover:text-emerald-700">
      <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 3h5v5"/><path d="M4 20 21 3"/><path d="M21 16v5h-5"/><path d="M15 15l6 6"/><path d="M4 4l5 5"/></svg>
      Shuffle
    </button>
    <button id="btn-reset" class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-rose-300 bg-white px-2 sm:px-3 py-2 text-xs sm:text-sm font-semibold text-rose-700 shadow-sm hover:border-rose-500 hover:bg-rose-50">
      <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      <span>Reset<span class="hidden sm:inline">&nbsp;progress</span></span>
    </button>
  </div>

  <!-- Embed deck data so the JS doesn't need to fetch -->
  <script id="deck-data" type="application/json" set:html={JSON.stringify({ deck: { title: deck.title_i18n ?? { en: deck.title }, cards: deck.cards }, id: deck.id })}></script>

  <style>
    .scene { perspective: 1400px; }
    .card-3d {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 3;
      transform-style: preserve-3d;
      transition: transform 600ms cubic-bezier(.2,.8,.2,1), opacity 350ms ease;
      will-change: transform;
    }
    @media (min-width: 640px) {
      .card-3d { aspect-ratio: 3 / 2; }
    }
    .card-3d.flipped { transform: rotateY(180deg); }
    .card-face {
      position: absolute; inset: 0;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      border-radius: 1.25rem;
      display: flex; align-items: center; justify-content: center;
      padding: 1.25rem;
      text-align: center;
      overflow: hidden;
      word-break: break-word;
      overflow-wrap: anywhere;
    }
    @media (min-width: 640px) {
      .card-face { padding: 1.75rem; }
    }
    .card-back { transform: rotateY(180deg); }
    .swipe-right { transform: translateX(140%) rotate(14deg) !important; opacity: 0 !important; }
    .swipe-left  { transform: translateX(-140%) rotate(-14deg) !important; opacity: 0 !important; }
    .swipe-in { animation: cardIn 350ms cubic-bezier(.2,.8,.2,1); }
    @keyframes cardIn {
      from { transform: translateY(24px) scale(.96); opacity: 0; }
      to   { transform: translateY(0) scale(1); opacity: 1; }
    }
    .tap-hint { animation: tapHint 1.6s ease-in-out infinite; }
    @keyframes tapHint {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
    .stack-card {
      position: absolute; inset: 0;
      border-radius: 1.25rem;
      pointer-events: none;
    }
    .urdu { font-family: 'Noto Naskh Arabic', serif; direction: rtl; }
  </style>

  <script is:inline>
    (function () {
      const STORAGE_KEY = "flashcards.progress.v1";
      const raw = document.getElementById("deck-data").textContent;
      const { deck: deckData } = JSON.parse(raw);

      let lang = localStorage.getItem("flashcards.lang") || "en";
      let deck = { title: deckData.title || {}, cards: ensureIds(deckData.cards || []) };
      let deckSig = signatureFor(deck);
      let learned = new Set();
      let queue = [];
      let currentId = null;
      let flipped = false;
      let animating = false;

      const els = {
        card: document.getElementById("card"),
        front: document.getElementById("front-content"),
        back: document.getElementById("back-content"),
        empty: document.getElementById("empty"),
        learnedCount: document.getElementById("learned-count"),
        remainingCount: document.getElementById("remaining-count"),
        progress: document.getElementById("progress-bar"),
        btnKnew: document.getElementById("btn-knew"),
        btnDidnt: document.getElementById("btn-didnt"),
        btnFlip: document.getElementById("btn-flip"),
        btnShuffle: document.getElementById("btn-shuffle"),
        btnReset: document.getElementById("btn-reset"),
        lang: document.getElementById("lang"),
      };
      els.lang.value = lang;

      function ensureIds(cards) {
        const seen = new Set();
        return cards.map((c) => {
          let id = c.id || `${(c.front?.en || c.front?.ur || "card")}__${(c.back?.en || c.back?.ur || "")}`;
          let unique = id, n = 1;
          while (seen.has(unique)) unique = `${id}#${++n}`;
          seen.add(unique);
          return { ...c, id: unique };
        });
      }

      function signatureFor(d) {
        const t = d.title?.en || d.title?.ur || "deck";
        return `${t}::${d.cards.length}::${d.cards.map((c) => c.id).join("|")}`.slice(0, 200);
      }

      function loadProgress() {
        try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}") || {}; }
        catch { return {}; }
      }
      function persist() {
        const all = loadProgress();
        all[deckSig] = { learned: [...learned], queue, ts: Date.now() };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
      }
      function restore() {
        const entry = loadProgress()[deckSig];
        if (entry && Array.isArray(entry.learned)) {
          learned = new Set(entry.learned);
          const remaining = deck.cards.map((c) => c.id).filter((id) => !learned.has(id));
          if (Array.isArray(entry.queue) && entry.queue.length) {
            const set = new Set(remaining);
            const ordered = entry.queue.filter((id) => set.has(id));
            for (const id of remaining) if (!ordered.includes(id)) ordered.push(id);
            queue = ordered;
          } else {
            queue = remaining;
          }
        } else {
          queue = deck.cards.map((c) => c.id);
        }
      }

      function appendLine(parent, text, isUrdu) {
        const div = document.createElement("div");
        div.className = isUrdu ? "urdu text-3xl sm:text-4xl leading-snug" : "leading-snug";
        div.textContent = text;
        parent.appendChild(div);
      }
      function renderSide(el, content) {
        el.innerHTML = "";
        if (!content) { el.textContent = "—"; return; }
        const en = content.en || "", ur = content.ur || "";
        if (lang === "en") { if (en) appendLine(el, en, false); else if (ur) appendLine(el, ur, true); }
        else if (lang === "ur") { if (ur) appendLine(el, ur, true); else if (en) appendLine(el, en, false); }
        else {
          if (en) appendLine(el, en, false);
          if (en && ur) {
            const sep = document.createElement("div");
            sep.className = "h-px bg-white/20 my-3";
            el.appendChild(sep);
          }
          if (ur) appendLine(el, ur, true);
        }
      }

      function currentCard() { return deck.cards.find((c) => c.id === currentId) || null; }

      function updateStats() {
        const total = deck.cards.length;
        els.learnedCount.textContent = String(learned.size);
        els.remainingCount.textContent = String(total - learned.size);
        els.progress.style.width = total ? `${Math.round((learned.size / total) * 100)}%` : "0%";
      }

      function renderCurrent() {
        const c = currentCard();
        if (!c) {
          els.empty.classList.remove("hidden");
          els.card.classList.add("invisible");
          els.btnKnew.disabled = true;
          els.btnDidnt.disabled = true;
          return;
        }
        els.empty.classList.add("hidden");
        els.card.classList.remove("invisible");
        els.btnKnew.disabled = false;
        els.btnDidnt.disabled = false;
        renderSide(els.front, c.front);
        renderSide(els.back, c.back);
      }

      function next(initial) {
        flipped = false;
        els.card.classList.remove("flipped");
        currentId = queue[0] || null;
        renderCurrent();
        if (!initial) {
          els.card.classList.add("swipe-in");
          setTimeout(() => els.card.classList.remove("swipe-in"), 360);
        }
      }

      function flip() {
        if (animating) return;
        flipped = !flipped;
        els.card.classList.toggle("flipped", flipped);
      }

      function decide(known) {
        if (!currentId || animating) return;
        animating = true;
        const id = currentId;
        if (known) { learned.add(id); queue = queue.filter((x) => x !== id); }
        else { queue = queue.filter((x) => x !== id); queue.push(id); }
        persist();
        updateStats();
        els.card.classList.add(known ? "swipe-right" : "swipe-left");
        setTimeout(() => {
          els.card.classList.remove("swipe-right", "swipe-left");
          animating = false;
          next(false);
        }, 420);
      }

      els.card.addEventListener("click", flip);
      els.btnFlip.addEventListener("click", flip);
      els.btnKnew.addEventListener("click", () => decide(true));
      els.btnDidnt.addEventListener("click", () => decide(false));
      els.btnShuffle.addEventListener("click", () => {
        for (let i = queue.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [queue[i], queue[j]] = [queue[j], queue[i]];
        }
        persist();
        next(false);
      });
      els.btnReset.addEventListener("click", () => {
        if (!confirm("Reset progress for this deck?")) return;
        learned = new Set();
        queue = deck.cards.map((c) => c.id);
        persist();
        updateStats();
        next(false);
      });
      els.lang.addEventListener("change", () => {
        lang = els.lang.value;
        localStorage.setItem("flashcards.lang", lang);
        renderCurrent();
      });
      window.addEventListener("keydown", (e) => {
        if (e.target && /^(INPUT|TEXTAREA|SELECT)$/.test(e.target.tagName)) return;
        if (e.key === " " || e.key === "Spacebar") { e.preventDefault(); flip(); }
        else if (e.key === "ArrowRight") { e.preventDefault(); decide(true); }
        else if (e.key === "ArrowLeft")  { e.preventDefault(); decide(false); }
      });

      restore();
      updateStats();
      next(true);
    })();
  </script>
</Layout>
