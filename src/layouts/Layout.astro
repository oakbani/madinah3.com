---
export interface Props {
  title?: string;
  description?: string;
}
const { title = "madinah3", description = "Flashcards, crosswords, and word searches." } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<!doctype html>
<html lang="en" class="bg-slate-950 text-slate-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Noto+Naskh+Arabic:wght@500;700&family=Noto+Kufi+Arabic:wght@400;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 font-sans antialiased">
    <header class="border-b border-slate-800/60 bg-slate-950/60 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
        <a href={`${base}/`} class="flex items-center gap-2 font-extrabold tracking-tight text-lg">
          <span class="inline-block h-6 w-6 rounded-md bg-gradient-to-br from-amber-300 to-fuchsia-500"></span>
          automation<span class="text-amber-300">·</span>3
        </a>
        <nav class="flex items-center gap-1 text-sm text-slate-300">
          <a class="rounded-lg px-3 py-1.5 hover:bg-slate-800/70" href={`${base}/`}>Home</a>
          <a class="rounded-lg px-3 py-1.5 hover:bg-slate-800/70" href={`${base}/#flashcards`}>Flashcards</a>
          <a class="rounded-lg px-3 py-1.5 hover:bg-slate-800/70" href={`${base}/#puzzles`}>Puzzles</a>
          <a class="rounded-lg px-3 py-1.5 hover:bg-slate-800/70" href={`${base}/#diagrams`}>Diagrams</a>
          <a class="rounded-lg px-3 py-1.5 hover:bg-slate-800/70" href={`${base}/blog/`}>Blog</a>
          <button id="change-name" type="button" class="ml-1 rounded-lg border border-slate-700 px-3 py-1.5 text-xs text-slate-300 hover:bg-slate-800/70">
            <span id="name-pill">Hi!</span>
          </button>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 sm:px-6 py-8">
      <slot />
    </main>

    <footer class="mx-auto max-w-5xl px-4 sm:px-6 py-10 text-center text-xs text-slate-500">
      Built with <a class="hover:text-slate-300" href="https://astro.build">Astro</a> · hosted on GitHub Pages
    </footer>

    <!-- Name prompt modal -->
    <div id="name-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/80 px-4">
      <form id="name-form" class="w-full max-w-sm rounded-2xl border border-slate-800 bg-slate-900 p-6 shadow-2xl">
        <h2 class="text-lg font-bold">What should we call you?</h2>
        <p class="mt-1 text-sm text-slate-400">Stored only in your browser. You can change it anytime.</p>
        <input id="name-input" type="text" required minlength="1" maxlength="40" autocomplete="given-name" placeholder="Your name"
          class="mt-4 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-sm outline-none focus:border-amber-400" />
        <div class="mt-4 flex justify-end gap-2">
          <button type="button" id="name-cancel" class="rounded-lg px-3 py-2 text-sm text-slate-400 hover:text-slate-200">Cancel</button>
          <button type="submit" class="rounded-lg bg-amber-300 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-amber-200">Save</button>
        </div>
      </form>
    </div>

    <script>
      import { profile } from "@/lib/storage";

      const modal = document.getElementById("name-modal")!;
      const form = document.getElementById("name-form") as HTMLFormElement;
      const input = document.getElementById("name-input") as HTMLInputElement;
      const cancel = document.getElementById("name-cancel")!;
      const pill = document.getElementById("name-pill")!;
      const changeBtn = document.getElementById("change-name")!;

      function openModal(prefill?: string | null) {
        if (prefill) input.value = prefill;
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        setTimeout(() => input.focus(), 50);
      }
      function closeModal() {
        modal.classList.remove("flex");
        modal.classList.add("hidden");
      }
      function refreshPill() {
        const name = profile.getName();
        pill.textContent = name ? `Hi, ${name}` : "Set name";
      }

      const existing = profile.getName();
      if (!existing) openModal();
      refreshPill();

      cancel.addEventListener("click", () => {
        if (profile.getName()) closeModal();
      });
      changeBtn.addEventListener("click", () => openModal(profile.getName() ?? ""));
      form.addEventListener("submit", (e) => {
        e.preventDefault();
        const v = input.value.trim();
        if (!v) return;
        profile.setName(v);
        refreshPill();
        closeModal();
        document.dispatchEvent(new CustomEvent("a3:name-changed", { detail: v }));
      });
    </script>
  </body>
</html>
